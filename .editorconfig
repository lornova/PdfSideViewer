root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{md,ps1}]
indent_style = space
indent_size = 4

[*.{sln,vcxproj,manifest}]
end_of_line = crlf
indent_style = space
indent_size = 2
