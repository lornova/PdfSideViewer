# Normalize line endings: LF in the repository, native on checkout for text.
* text=auto

# C++ sources and docs
*.cpp text
*.h text
*.md text
*.ps1 text

# Visual Studio files are traditionally CRLF
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.manifest text eol=crlf

# Binary test assets
*.pdf binary
*.png binary
*.ico binary
